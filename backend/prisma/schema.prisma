generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  roleId    Int
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id])
}

model Role {
  id    Int    @id @default(autoincrement())
  role  String @unique
  users User[]
}

model Product {
  id Int       @id @default(autoincrement())
  name String
  price Int
  count Int
  group String
  history StockAction[]
  supplyItems SupplyItem[]
  order OrderItem[]
}

model StockAction {
  id Int      @id @default(autoincrement())
  type ActionType
  amount Int
  createdAt DateTime @default(now())

  Product Product @relation(fields: [productId],references:[id])
  productId Int
}

enum ActionType{
  INCOMING
  OUTGOING
}

model SupplyOrder {
  id          Int      @id @default(autoincrement())
  supplier    String  
  totalAmount Int      
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
  
  items       SupplyItem[]
}

model SupplyItem {
  id            Int         @id @default(autoincrement())
  quantity      Int         
  priceAtOrder  Int         
  product       Product     @relation(fields: [productId], references: [id])
  productId     Int
  
  order         SupplyOrder @relation(fields: [orderId], references: [id])
  orderId       Int
}

model Order{
  id            Int      @id @default(autoincrement())
  clientName    String
  totalPrice    Int
  createdAt     DateTime @default(now())
  items         OrderItem[]
}

model OrderItem{
  id            Int       @id @default(autoincrement())
  quantity      Int
  price         Int

  product       Product   @relation(fields:[productId], references:[id])
  productId     Int

  order         Order     @relation(fields:[orderId], references:[id])
  orderId       Int
}
